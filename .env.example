# Copia este archivo a .env.local y completa los valores.

# Base de datos Neon (Postgres). En la v1 no es necesario (usa la semilla local);
# se activa al conectar Neon. Formato:
# DATABASE_URL="postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/fmc?sslmode=require"
DATABASE_URL=

# (Opcional) Sentry para monitoreo de errores
# SENTRY_DSN=

# Tasa de impuesto de renta por defecto (RN2). También configurable en la app.
NEXT_PUBLIC_TASA_IMPORENTA=0.35
